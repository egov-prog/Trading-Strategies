group_strat = '=== Strategy Execution Settings ==='

i_useBOS          = input.bool(true,  'Enter on BOS',                     group = group_strat, inline = 'sig1')
i_useCHoCH        = input.bool(true,  'Enter on CHoCH',                   group = group_strat, inline = 'sig1')
i_useOB           = input.bool(true,  'Enter on Order Block',             group = group_strat, inline = 'sig2')
