// ---- 1. FAIR VALUE GAPS -----------------------------------------------------------------------

fvgMinSize = i_fvgThresh / 100
bullFVG    = i_showFVG and low > high[2] and close[1] > open[1] and (low - high[2]) / high[2] >= fvgMinSize
bearFVG    = i_showFVG and high < low[2] and close[1] < open[1] and (low[2] - high) / low[2] >= fvgMinSize

conf_FVG    = f_confidence(3)
total_FVG   = array.get(sig_total, 3)

var array<box> fvgBoxes = array.new_box()

if bullFVG
    fvgTop    = low
    fvgBottom = high[2]
    boxCol    = i_showAdaptive ? f_boxColor(i_bullFVGColor, conf_FVG) : i_bullFVGColor
    newBox    = box.new(bar_index - 2, fvgTop, bar_index + 20, fvgBottom, border_color = color.new(#76FF03, 80), bgcolor = boxCol)
    array.push(fvgBoxes, newBox)
    if array.size(fvgBoxes) > 5
        box.delete(array.shift(fvgBoxes))
    lblText   = i_showConfLabel and i_showAdaptive ? 'FVG' + f_confStr(conf_FVG, total_FVG) : 'FVG'
    label.new(bar_index - 1, math.avg(fvgTop, fvgBottom), lblText, style = label.style_label_right, color = color.new(#76FF03, 85), textcolor = #76FF03, size = size.tiny)
    f_record(3, 1)

if bearFVG
    fvgTop    = low[2]
    fvgBottom = high
    boxCol    = i_showAdaptive ? f_boxColor(i_bearFVGColor, conf_FVG) : i_bearFVGColor
    newBox    = box.new(bar_index - 2, fvgTop, bar_index + 20, fvgBottom, border_color = color.new(#E040FB, 80), bgcolor = boxCol)
    array.push(fvgBoxes, newBox)
    if array.size(fvgBoxes) > 5
        box.delete(array.shift(fvgBoxes))
    lblText   = i_showConfLabel and i_showAdaptive ? 'FVG' + f_confStr(conf_FVG, total_FVG) : 'FVG'
    label.new(bar_index - 1, math.avg(fvgTop, fvgBottom), lblText, style = label.style_label_right, color = color.new(#E040FB, 85), textcolor = #E040FB, size = size.tiny)
    f_record(3, -1)

if array.size(fvgBoxes) > 0
    for i = array.size(fvgBoxes) - 1 to 0 by 1
        b       = array.get(fvgBoxes, i)
        bTop    = box.get_top(b)
        bBottom = box.get_bottom(b)
        if close >= bBottom and close <= bTop or high >= bBottom and low <= bTop
            box.set_right(b, bar_index)
            box.set_border_color(b, color.new(color.gray, 80))
            box.set_bgcolor(b, color.new(color.gray, 95))
            array.remove(fvgBoxes, i)
        else
            box.set_right(b, bar_index + 20)

// ---- 2. ORDER BLOCKS --------------------------------------------------------------------------

var array<box>  obBoxes    = array.new_box()
var array<bool> obIsBull   = array.new_bool()
var array<bool> obMitigated = array.new_bool()

bullOB   = i_showOB and bearCandle[1] and bullCandle and close - open > ta.atr(i_obLookback) * 0.5 and close > high[1]
bearOB   = i_showOB and bullCandle[1] and bearCandle and open - close > ta.atr(i_obLookback) * 0.5 and close < low[1]

conf_OB  = f_confidence(2)
total_OB = array.get(sig_total, 2)

if bullOB
    boxCol  = i_showAdaptive ? f_boxColor(i_bullOBColor, conf_OB) : i_bullOBColor
    newOB   = box.new(bar_index - 1, math.max(open[1], close[1]), bar_index + 30, math.min(open[1], close[1]), border_color = color.new(#00E5FF, 80), bgcolor = boxCol, border_width = 1)
    array.push(obBoxes, newOB)
    array.push(obIsBull, true)
    array.push(obMitigated, false)
    lblText = i_showConfLabel and i_showAdaptive ? 'OB' + f_confStr(conf_OB, total_OB) : 'OB'
    label.new(bar_index - 1, math.max(open[1], close[1]), lblText, style = label.style_label_down, color = color.new(#00E5FF, 85), textcolor = #00E5FF, size = size.tiny)
    f_record(2, 1)

if bearOB
    boxCol  = i_showAdaptive ? f_boxColor(i_bearOBColor, conf_OB) : i_bearOBColor
    newOB   = box.new(bar_index - 1, math.max(open[1], close[1]), bar_index + 30, math.min(open[1], close[1]), border_color = color.new(#FF1744, 80), bgcolor = boxCol, border_width = 1)
    array.push(obBoxes, newOB)
    array.push(obIsBull, false)
    array.push(obMitigated, false)
    lblText = i_showConfLabel and i_showAdaptive ? 'OB' + f_confStr(conf_OB, total_OB) : 'OB'
    label.new(bar_index - 1, math.min(open[1], close[1]), lblText, style = label.style_label_up, color = color.new(#FF1744, 85), textcolor = #FF1744, size = size.tiny)
    f_record(2, -1)

if array.size(obBoxes) > 0
    for i = array.size(obBoxes) - 1 to 0 by 1
        b           = array.get(obBoxes, i)
        bTop        = box.get_top(b)
        bBottom     = box.get_bottom(b)
        isBull      = array.get(obIsBull, i)
        isMitigated = array.get(obMitigated, i)
        if not isMitigated and (isBull and low <= bTop and low >= bBottom or not isBull and high >= bBottom and high <= bTop)
            array.set(obMitigated, i, true)
            if i_showMitigatedOB
                box.set_bgcolor(b, color.new(isBull ? #00e5ff : #ff1744, 97))
                box.set_border_color(b, color.new(isBull ? #00e5ff : #ff1744, 85))
                box.set_border_width(b, 1)
                box.set_border_style(b, line.style_dashed)
            else
                box.delete(b)
                array.remove(obBoxes, i)
                array.remove(obIsBull, i)
                array.remove(obMitigated, i)
        else
            box.set_right(b, bar_index + 30)

// ---- 3. BREAKER BLOCKS ------------------------------------------------------------------------

if i_showBB and array.size(obBoxes) > 0
    for i = array.size(obBoxes) - 1 to 0 by 1
        if i < array.size(obMitigated) and array.get(obMitigated, i)
            b      = array.get(obBoxes, i)
            bTop   = box.get_top(b)
            bBott  = box.get_bottom(b)
            isBull = array.get(obIsBull, i)
            if isBull and close < bBott
                box.set_bgcolor(b, i_bearBBColor)
                box.set_border_color(b, color.new(#e91e63, 50))
            else if not isBull and close > bTop
                box.set_bgcolor(b, i_bullBBColor)
                box.set_border_color(b, color.new(#00bcd4, 50))

// ---- 4. MARKET STRUCTURE: BOS & CHoCH ---------------------------------------------------------

swingHigh = ta.pivothigh(high, i_bosLookback, i_bosLookback)
swingLow  = ta.pivotlow(low,  i_bosLookback, i_bosLookback)

var float lastSwingHigh    = na
var float lastSwingLow     = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na
var bool  upTrend          = true

if not na(swingHigh)
    lastSwingHigh    := swingHigh
    lastSwingHighBar := bar_index - i_bosLookback
    lastSwingHighBar

if not na(swingLow)
    lastSwingLow    := swingLow
    lastSwingLowBar := bar_index - i_bosLookback
    lastSwingLowBar

bosBull   = i_showBOS   and upTrend      and not na(lastSwingHigh) and close > lastSwingHigh and close[1] <= lastSwingHigh
bosBear   = i_showBOS   and not upTrend  and not na(lastSwingLow)  and close < lastSwingLow  and close[1] >= lastSwingLow
chochBull = i_showCHoCH and not upTrend  and not na(lastSwingHigh) and close > lastSwingHigh and close[1] <= lastSwingHigh
chochBear = i_showCHoCH and upTrend      and not na(lastSwingLow)  and close < lastSwingLow  and close[1] >= lastSwingLow

if bosBull or chochBull
    upTrend := true
    upTrend
if bosBear or chochBear
    upTrend := false
    upTrend

conf_BOS    = f_confidence(0)
total_BOS   = array.get(sig_total, 0)
conf_CHOCH  = f_confidence(1)
total_CHOCH = array.get(sig_total, 1)

if bosBull
    lblText = i_showConfLabel and i_showAdaptive ? 'BOS' + f_confStr(conf_BOS, total_BOS) : 'BOS'
    line.new(lastSwingHighBar, lastSwingHigh, bar_index, lastSwingHigh, color = color.new(#00BFA5, 0), width = 2, style = line.style_solid)
    label.new(bar_index, lastSwingHigh, lblText, style = label.style_label_left, color = color.new(#00BFA5, 85), textcolor = #00BFA5, size = size.tiny)
    f_record(0, 1)

if bosBear
    lblText = i_showConfLabel and i_showAdaptive ? 'BOS' + f_confStr(conf_BOS, total_BOS) : 'BOS'
    line.new(lastSwingLowBar, lastSwingLow, bar_index, lastSwingLow, color = color.new(#E040FB, 0), width = 2, style = line.style_solid)
    label.new(bar_index, lastSwingLow, lblText, style = label.style_label_left, color = color.new(#E040FB, 85), textcolor = #E040FB, size = size.tiny)
    f_record(0, -1)

if chochBull
    lblText = i_showConfLabel and i_showAdaptive ? 'CHoCH' + f_confStr(conf_CHOCH, total_CHOCH) : 'CHoCH'
    line.new(lastSwingHighBar, lastSwingHigh, bar_index, lastSwingHigh, color = color.new(#76FF03, 0), width = 2, style = line.style_solid)
    label.new(bar_index, lastSwingHigh, lblText, style = label.style_label_left, color = color.new(#76FF03, 85), textcolor = #76FF03, size = size.tiny)
    f_record(1, 1)

if chochBear
    lblText = i_showConfLabel and i_showAdaptive ? 'CHoCH' + f_confStr(conf_CHOCH, total_CHOCH) : 'CHoCH'
    line.new(lastSwingLowBar, lastSwingLow, bar_index, lastSwingLow, color = color.new(#00E5FF, 0), width = 2, style = line.style_solid)
    label.new(bar_index, lastSwingLow, lblText, style = label.style_label_left, color = color.new(#00E5FF, 85), textcolor = #00E5FF, size = size.tiny)
    f_record(1, -1)

// ---- 5. LIQUIDITY SWEEPS ----------------------------------------------------------------------

recentHigh = ta.highest(high[1], i_liqLookback)
recentLow  = ta.lowest(low[1],  i_liqLookback)

bslSweep = i_showLiq and high > recentHigh and close < recentHigh
sslSweep = i_showLiq and low  < recentLow  and close > recentLow

conf_LIQ  = f_confidence(4)
total_LIQ = array.get(sig_total, 4)

if bslSweep
    lblText = i_showConfLabel and i_showAdaptive ? 'SwMp' + f_confStr(conf_LIQ, total_LIQ) : 'SwMp'
    line.new(bar_index, recentHigh, bar_index, high, color = color.new(#FF6B35, 0), width = 2)
    label.new(bar_index, high, lblText, style = label.style_label_down, color = color.new(#FF6B35, 80), textcolor = #FF6B35, size = size.tiny)
    f_record(4, -1)

if sslSweep
    lblText = i_showConfLabel and i_showAdaptive ? 'SwMp' + f_confStr(conf_LIQ, total_LIQ) : 'SwMp'
    line.new(bar_index, recentLow, bar_index, low, color = color.new(#FF6B35, 0), width = 2)
    label.new(bar_index, low, lblText, style = label.style_label_up, color = color.new(#FF6B35, 80), textcolor = #FF6B35, size = size.tiny)
    f_record(4, 1)

// ---- 6. EQUAL HIGHS / EQUAL LOWS --------------------------------------------------------------

eqTolerance  = i_eqThresh / 100
eqhHasValues = not na(swingHigh) and not na(lastSwingHigh)
eqhDiffOk    = eqhHasValues and math.abs(swingHigh - lastSwingHigh) / lastSwingHigh < eqTolerance
eqhDiffBar   = bar_index - i_bosLookback != lastSwingHighBar
eqhCondition = i_showEQ and eqhHasValues and eqhDiffOk and eqhDiffBar
eqlHasValues = not na(swingLow) and not na(lastSwingLow)
eqlDiffOk    = eqlHasValues and math.abs(swingLow - lastSwingLow) / lastSwingLow < eqTolerance
eqlDiffBar   = bar_index - i_bosLookback != lastSwingLowBar
eqlCondition = i_showEQ and eqlHasValues and eqlDiffOk and eqlDiffBar

if eqhCondition
    line.new(lastSwingHighBar, lastSwingHigh, bar_index - i_bosLookback, swingHigh, color = i_eqhColor, width = 1, style = line.style_dotted)
    label.new(bar_index - i_bosLookback, swingHigh, 'EQH 📊', style = label.style_label_down, color = color.new(i_eqhColor, 60), textcolor = color.white, size = size.tiny)

if eqlCondition
    line.new(lastSwingLowBar, lastSwingLow, bar_index - i_bosLookback, swingLow, color = i_eqlColor, width = 1, style = line.style_dotted)
    label.new(bar_index - i_bosLookback, swingLow, 'EQL 📊', style = label.style_label_up, color = color.new(i_eqlColor, 60), textcolor = color.white, size = size.tiny)

// ---- 7. PREMIUM & DISCOUNT ZONES --------------------------------------------------------------

pdHigh   = ta.highest(high, i_pdLookback)
pdLow    = ta.lowest(low,  i_pdLookback)
pdMid    = math.avg(pdHigh, pdLow)
pdEqHigh = pdMid + (pdHigh - pdLow) * 0.05
pdEqLow  = pdMid - (pdHigh - pdLow) * 0.05

if i_showPD and barstate.islast
    box.new(bar_index - i_pdLookback, pdHigh, bar_index + 5, pdEqHigh, border_color = color.new(#e91e63, 70), bgcolor = i_premColor)
    box.new(bar_index - i_pdLookback, pdEqHigh, bar_index + 5, pdEqLow, border_color = color.new(#9c27b0, 70), bgcolor = i_eqColor)
    box.new(bar_index - i_pdLookback, pdEqLow, bar_index + 5, pdLow, border_color = color.new(#26a69a, 70), bgcolor = i_discColor)
    label.new(bar_index + 5, pdHigh, 'Premium', style = label.style_label_left, color = color.new(#e91e63, 70), textcolor = color.white, size = size.tiny)
    label.new(bar_index + 5, pdMid, 'EQ', style = label.style_label_left, color = color.new(#9c27b0, 70), textcolor = color.white, size = size.tiny)
    label.new(bar_index + 5, pdLow, 'Discount', style = label.style_label_left, color = color.new(#26a69a, 70), textcolor = color.white, size = size.tiny)

// ---- 8. ICT KILL ZONES ------------------------------------------------------------------------

sessionAsian  = timeframe.isintraday ? time(timeframe.period, '0000-0400:1234567') : na
sessionLondon = timeframe.isintraday ? time(timeframe.period, '0700-1000:1234567') : na
sessionNY     = timeframe.isintraday ? time(timeframe.period, '1300-1600:1234567') : na

inAsian  = not na(sessionAsian)
inLondon = not na(sessionLondon)
inNY     = not na(sessionNY)

conf_KZ_Asian  = f_confidence(5)
conf_KZ_London = f_confidence(6)
conf_KZ_NY     = f_confidence(7)

isFirstAsianBar  = i_showKZ and inAsian  and na(sessionAsian[1])
isFirstLondonBar = i_showKZ and inLondon and na(sessionLondon[1])
isFirstNYBar     = i_showKZ and inNY     and na(sessionNY[1])

if isFirstAsianBar
    f_record(5, upTrend ? 1 : -1)
if isFirstLondonBar
    f_record(6, upTrend ? 1 : -1)
if isFirstNYBar
    f_record(7, upTrend ? 1 : -1)

bestKZConf   = math.max(conf_KZ_Asian, math.max(conf_KZ_London, conf_KZ_NY))
asianBright  = i_showAdaptive and conf_KZ_Asian  >= bestKZConf - 0.05
londonBright = i_showAdaptive and conf_KZ_London >= bestKZConf - 0.05
nyBright     = i_showAdaptive and conf_KZ_NY     >= bestKZConf - 0.05

asianBgColor  = inAsian  ? (asianBright  ? i_asianKZColor  : color.new(#9c27b0, 96)) : na
londonBgColor = inLondon ? (londonBright ? i_londonKZColor : color.new(#2196f3, 96)) : na
nyBgColor     = inNY     ? (nyBright     ? i_nyKZColor     : color.new(#ff9800, 96)) : na

bgcolor(i_showKZ ? asianBgColor  : na, title = 'Asian Kill Zone')
bgcolor(i_showKZ ? londonBgColor : na, title = 'London Kill Zone')
bgcolor(i_showKZ ? nyBgColor     : na, title = 'NY Kill Zone')

if isFirstAsianBar
    total_kzA = array.get(sig_total, 5)
    lblText   = i_showConfLabel and i_showAdaptive ? 'Asian KZ' + f_confStr(conf_KZ_Asian, total_kzA) : 'Asian KZ 🌙'
    label.new(bar_index, high, lblText, style = label.style_label_down, color = color.new(#9c27b0, 60), textcolor = color.white, size = size.tiny)

if isFirstLondonBar
    total_kzL = array.get(sig_total, 6)
    lblText   = i_showConfLabel and i_showAdaptive ? 'London KZ' + f_confStr(conf_KZ_London, total_kzL) : 'London KZ'
    label.new(bar_index, high, lblText, style = label.style_label_down, color = color.new(#2196f3, 60), textcolor = color.white, size = size.tiny)

if isFirstNYBar
    total_kzN = array.get(sig_total, 7)
    lblText   = i_showConfLabel and i_showAdaptive ? 'NY KZ' + f_confStr(conf_KZ_NY, total_kzN) : 'NY KZ'
    label.new(bar_index, high, lblText, style = label.style_label_down, color = color.new(#ff9800, 60), textcolor = color.white, size = size.tiny)

// ---- 9. POWER OF 3 (AMD) ----------------------------------------------------------------------

amdAccumulation = i_showPO3 and math.abs(close - open) < ta.atr(14) * 0.3 and math.abs(high - low) < ta.atr(14) * 0.6
amdManipulation = i_showPO3 and (bslSweep or sslSweep)
amdDistribution = i_showPO3 and (bosBull or bosBear)

if amdAccumulation
    label.new(bar_index, low, 'A', style = label.style_label_up, color = color.new(#607d8b, 70), textcolor = color.white, size = size.tiny, tooltip = 'PO3: Accumulation Phase')
if amdManipulation
    label.new(bar_index, bslSweep ? high : low, 'M', style = bslSweep ? label.style_label_down : label.style_label_up, color = color.new(#ff5722, 70), textcolor = color.white, size = size.tiny, tooltip = 'PO3: Manipulation Phase - Liquidity Grab')
if amdDistribution
    label.new(bar_index, bosBull ? high : low, 'D', style = bosBull ? label.style_label_down : label.style_label_up, color = color.new(#8bc34a, 70), textcolor = color.white, size = size.tiny, tooltip = 'PO3: Distribution Phase - Real Move')

// ================================================================================================== //
// --- STRATEGY EXECUTION ENGINE ----------------------------------------------------------------- //
// ================================================================================================== //

// Kill Zone active check
kzActive = (i_kzAsian and inAsian) or (i_kzLondon and inLondon) or (i_kzNY and inNY)
kzOk     = not i_kzFilter or kzActive

// Premium/Discount zone check
inDiscount = close < pdEqLow
inPremium  = close > pdEqHigh

// Confidence gate helpers
confOk_BOS   = not i_confGate or conf_BOS   >= i_highConfThresh / 100.0
confOk_CHOCH = not i_confGate or conf_CHOCH >= i_highConfThresh / 100.0
confOk_OB    = not i_confGate or conf_OB    >= i_highConfThresh / 100.0
confOk_FVG   = not i_confGate or conf_FVG   >= i_highConfThresh / 100.0
confOk_LIQ   = not i_confGate or conf_LIQ   >= i_highConfThresh / 100.0

// PD zone checks per direction
pdLongOk  = not i_pdFilter or inDiscount
pdShortOk = not i_pdFilter or inPremium

// --- NEW v2: HTF Bias filter ---
htfLongOk  = not i_useHTFBias or htfBullish
htfShortOk = not i_useHTFBias or htfBearish

// --- NEW v2: PDH/PDL sweep confirmation ---
// Long requires PDL swept today (stop hunt below prior day low before longs)
// Short requires PDH swept today (stop hunt above prior day high before shorts)
pdhSweptOk = not i_usePDHPDL or pdhSweptToday
pdlSweptOk = not i_usePDHPDL or pdlSweptToday

// Composite long/short signals (with v2 filters added)
longSignal  = kzOk and canTrade and htfLongOk and pdlSweptOk and (
     (i_useBOS   and bosBull   and confOk_BOS   and pdLongOk)  or
     (i_useCHoCH and chochBull and confOk_CHOCH and pdLongOk)  or
     (i_useOB    and bullOB    and confOk_OB    and pdLongOk)   or
     (i_useFVG   and bullFVG   and confOk_FVG   and pdLongOk)   or
     (i_useSweep and sslSweep  and confOk_LIQ   and pdLongOk))

shortSignal = kzOk and canTrade and htfShortOk and pdhSweptOk and (
     (i_useBOS   and bosBear   and confOk_BOS   and pdShortOk) or
     (i_useCHoCH and chochBear and confOk_CHOCH and pdShortOk) or
     (i_useOB    and bearOB    and confOk_OB    and pdShortOk)  or
     (i_useFVG   and bearFVG   and confOk_FVG   and pdShortOk)  or
     (i_useSweep and bslSweep  and confOk_LIQ   and pdShortOk))

// ATR-based SL/TP distances
atrVal   = baseATR
slDist   = i_slATR  * atrVal
tpDist   = i_tpATR  * atrVal
tp1Dist  = i_tp1ATR * atrVal
tp2Dist  = i_tp2ATR * atrVal
trOffset = i_trailATR * atrVal

// Entry logic — no pyramiding
if longSignal and strategy.position_size == 0
    strategy.entry('Long', strategy.long, comment = 'L')
    label.new(bar_index, low, '🟢 BUY', color = color.new(#00E676, 0), style = label.style_label_up, textcolor = color.white, size = size.normal)
    if i_useDualTP
        strategy.exit('Long TP1', 'Long', limit = close + tp1Dist, qty_percent = 50,  comment = 'TP1')
        strategy.exit('Long TP2', 'Long', limit = close + tp2Dist, stop  = close - slDist, comment = 'TP2/SL')
    else if i_trailSL
        strategy.exit('Long Exit', 'Long', trail_points = trOffset / syminfo.mintick, trail_offset = trOffset / syminfo.mintick)
    else
        strategy.exit('Long Exit', 'Long', stop = close - slDist, limit = close + tpDist)

if shortSignal and strategy.position_size == 0
    strategy.entry('Short', strategy.short, comment = 'S')
    label.new(bar_index, high, '🔴 SELL', color = color.new(#FF1744, 0), style = label.style_label_down, textcolor = color.white, size = size.normal)
    if i_useDualTP
        strategy.exit('Short TP1', 'Short', limit = close - tp1Dist, qty_percent = 50,  comment = 'TP1')
        strategy.exit('Short TP2', 'Short', limit = close - tp2Dist, stop  = close + slDist, comment = 'TP2/SL')
    else if i_trailSL
        strategy.exit('Short Exit', 'Short', trail_points = trOffset / syminfo.mintick, trail_offset = trOffset / syminfo.mintick)
    else
        strategy.exit('Short Exit', 'Short', stop = close + slDist, limit = close - tpDist)

// ================================================================================================== //
// --- DASHBOARDS -------------------------------------------------------------------------------- //
// ================================================================================================== //

f_wr(idx) =>
    t = array.get(sig_total, idx)
    w = array.get(sig_wins, idx)
    t < 3 ? 'new' : str.tostring(math.round(w / t * 100)) + '%'

f_wrColor(idx) =>
    t = array.get(sig_total, idx)
    if t < 3
        color.gray
    else
        score = array.get(sig_wins, idx) / t
        score >= i_highConfThresh / 100.0 ? color.new(#4caf50, 0) : score >= i_lowConfThresh / 100.0 ? color.orange : color.new(color.gray, 40)

// --- ICT/SMC Signal Dashboard (top right) — expanded with v2 rows ---
// Rows: header, Trend, BOS, CHoCH, Liq Sweep, FVG, Order Block, PD Zone, Kill Zone, EQH/EQL, ATR Ratio
//       + HTF Bias, PDH/PDL, Loss Streak, Trade Status  => 15 rows total
var table dash = table.new(position.top_right, 2, 15, border_width = 1, border_color = color.new(#00D9FF, 50), frame_color = color.new(#00D9FF, 50), frame_width = 1)

if barstate.islast
    table.cell(dash, 0, 0, '⚡ ICT/SMC', text_color = color.new(#00F5FF, 0), bgcolor = color.new(#1A1F3A, 30), text_size = size.small, text_halign = text.align_center)
    table.cell(dash, 1, 0, 'Status',     text_color = color.new(#00D9FF, 40), bgcolor = color.new(#1A1F3A, 30), text_size = size.small, text_halign = text.align_center)
    table.cell(dash, 0, 1, 'Trend',      text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 1, 1, upTrend ? '▲ Bullish' : '▼ Bearish', text_color = upTrend ? color.new(#76FF03, 0) : color.new(#FF1744, 0), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 0, 2, 'BOS',        text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 1, 2, bosBull ? 'Bull ▲' : bosBear ? 'Bear ▼' : '-', text_color = bosBull ? color.new(#00BFA5, 0) : bosBear ? color.new(#E040FB, 0) : color.new(#8B93FF, 50), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 0, 3, 'CHoCH',      text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 1, 3, chochBull ? 'Bull ▲' : chochBear ? 'Bear ▼' : '-', text_color = chochBull ? color.new(#76FF03, 0) : chochBear ? color.new(#00E5FF, 0) : color.new(#8B93FF, 50), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 0, 4, 'Liq Sweep',  text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 1, 4, bslSweep ? 'BSL ▲' : sslSweep ? 'SSL ▼' : '-', text_color = bslSweep ? color.new(#FF6B35, 0) : sslSweep ? color.new(#FF6B35, 0) : color.new(#8B93FF, 50), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 0, 5, 'FVG',        text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 1, 5, bullFVG ? 'Bull' : bearFVG ? 'Bear' : '-', text_color = bullFVG ? color.new(#76FF03, 0) : bearFVG ? color.new(#E040FB, 0) : color.new(#8B93FF, 50), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 0, 6, 'Order Block',text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 1, 6, bullOB ? 'Bull OB' : bearOB ? 'Bear OB' : '-', text_color = bullOB ? color.new(#00E5FF, 0) : bearOB ? color.new(#FF1744, 0) : color.new(#8B93FF, 50), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    pdZone      = close > pdEqHigh ? 'Premium' : close < pdEqLow ? 'Discount' : 'EQ'
    pdZoneColor = close > pdEqHigh ? color.new(#FF1744, 0) : close < pdEqLow ? color.new(#00E676, 0) : color.new(#C77DFF, 0)
    table.cell(dash, 0, 7, 'PD Zone',    text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 1, 7, pdZone,       text_color = pdZoneColor,            bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    kzActiveStr = inNY ? 'NY' : inLondon ? 'London' : inAsian ? 'Asian' : 'Off-Session'
    kzColor     = inNY ? color.new(#FFB627, 0) : inLondon ? color.new(#00D9FF, 0) : inAsian ? color.new(#C77DFF, 0) : color.new(#8B93FF, 50)
    table.cell(dash, 0, 8, 'Kill Zone',  text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 1, 8, kzActiveStr,  text_color = kzColor,                bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 0, 9, 'EQH/EQL',   text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 1, 9, eqhCondition ? 'EQH ⚠' : eqlCondition ? 'EQL ⚠' : '-', text_color = eqhCondition ? color.new(#00E676, 0) : eqlCondition ? color.new(#FF1744, 0) : color.new(#8B93FF, 50), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 0, 10, 'ATR Ratio', text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 1, 10, str.tostring(math.round(atrRatio * 100) / 100) + 'x', text_color = atrRatio > 1.2 ? color.new(#FF1744, 0) : atrRatio < 0.8 ? color.new(#00E5FF, 0) : color.new(#8B93FF, 30), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    // --- v2 rows ---
    table.cell(dash, 0, 11, 'HTF Bias',   text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 1, 11, htfBullish ? '4H Bull ▲' : '4H Bear ▼', text_color = htfBullish ? color.new(#76FF03, 0) : color.new(#FF1744, 0), bgcolor = color.new(#0A0E27, 50), text_size = size.tiny)
    table.cell(dash, 0, 12, 'PDH/PDL',    text_color = color.new(#8B93FF, 30), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
    table.cell(dash, 1, 12, (pdhSweptToday ? 'PDH ✓' : 'PDH –') + ' / ' + (pdlSweptToday ? 'PDL ✓' : 'PDL –'), text_color = pdhSweptToday or pdlSweptToday ? color.new(#FFB627, 0) : color.new(#8B93FF, 50), bgcolor = color.new(#0F1629, 40), text_size = size.tiny)
