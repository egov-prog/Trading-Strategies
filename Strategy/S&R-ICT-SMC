i_nyKZColor       = input.color(color.new(#ff9800, 88), 'NY KZ', group = group_ict_smc, inline = 'KZcol')
i_showPO3         = input.bool(false, 'Power of 3 Labels (AMD)', group = group_ict_smc)
i_showBB          = input.bool(true, 'Breaker Blocks', group = group_ict_smc)
