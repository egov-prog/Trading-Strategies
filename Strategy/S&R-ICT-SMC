i_kzLondon        = input.bool(true,  'London',                           group = group_strat, inline = 'kz')
i_kzNY            = input.bool(true,  'NY',                               group = group_strat, inline = 'kz')
i_pdFilter        = input.bool(true,  'PD Zone Filter (Long in Discount, Short in Premium)', group = group_strat)
i_slATR           = input.float(1.5,  'Stop Loss (ATR x)',                group = group_strat, minval = 0.1, step = 0.1)
i_tpATR           = input.float(3.0,  'Take Profit (ATR x)',              group = group_strat, minval = 0.1, step = 0.1)
i_trailSL         = input.bool(false, 'Use Trailing Stop',                group = group_strat)
i_trailATR        = input.float(1.0,  'Trail Offset (ATR x)',             group = group_strat, minval = 0.1, step = 0.1)

// ================================================================================================== //
// --- NEW v2 INPUTS: HTF BIAS + PDH/PDL SWEEP + LOSS STREAK + DUAL TP -------------------------- //
// ================================================================================================== //

group_v2 = '=== v2 Enhancements ==='

i_useHTFBias      = input.bool(true,  'HTF Bias Filter (4H SMA 50)',      group = group_v2, tooltip = 'Only long when 4H close > 4H SMA50 (bullish bias), only short when below (bearish bias)')
i_usePDHPDL       = input.bool(true,  'Require PDH/PDL Sweep Before Entry', group = group_v2, tooltip = 'Only enter after price has swept prior day high (for shorts) or prior day low (for longs)')
i_useLossStreak   = input.bool(true,  'Loss Streak Kill Switch',          group = group_v2, tooltip = 'Pause all entries after N consecutive losses')
i_maxLossStreak   = input.int(3,      'Max Consecutive Losses',           group = group_v2, minval = 1, maxval = 10)
i_useDualTP       = input.bool(true,  'Dual Take Profit (TP1 + TP2)',     group = group_v2, tooltip = 'Exit 50% at TP1, remainder at TP2')
i_tp1ATR          = input.float(1.5,  'TP1 (ATR x)',                      group = group_v2, minval = 0.1, step = 0.1)
i_tp2ATR          = input.float(3.0,  'TP2 (ATR x)',                      group = group_v2, minval = 0.1, step = 0.1)

// ================================================================================================== //
// --- BASE CALCULATIONS ------------------------------------------------------------------------- //
// ================================================================================================== //

risingVol    = nzVolume >= nzVolume[1]
bullCandle   = close > open
bearCandle   = close < open
risingPrice  = close > close[1]
fallingPrice = close < close[1]
lwstPrice    = ta.lowest(low, 3)
hstPrice     = ta.highest(high, 3)

// Adaptive ATR
baseATR      = ta.atr(i_atrLength)
sessionATR   = ta.sma(baseATR, 20)
atrRatio     = baseATR / math.max(sessionATR, 0.000001)
adaptiveMult = i_adaptiveATR ? i_atrMult * math.max(0.8, math.min(1.5, atrRatio)) : i_atrMult
weightedATR  = adaptiveMult * baseATR

range_1      = math.abs(high - low)
x2           = timenow + 7 * math.round(ta.change(time))

var sProcessing = false
if srLookbackRange == 'Visible Range'
    sProcessing := time >= chart.left_visible_bar_time
    sProcessing
else
    sProcessing := time > timenow - i_lenLookback * (timeframe.isintraday ? timeframe.multiplier * 86400000 / 1440 : timeframe.multiplier * 86400000)
    sProcessing

falling = if i_sourceSnR == 'Volume'
    bearCandle and bearCandle[1] and bearCandle[2] and nzVolume > i_vSMA and risingVol and risingVol[1]
else
    bearCandle and bearCandle[1] and bearCandle[2] and fallingPrice and fallingPrice[1] and fallingPrice[2]

rising = if i_sourceSnR == 'Volume'
    bullCandle and bullCandle[1] and bullCandle[2] and nzVolume > i_vSMA and risingVol and risingVol[1]
else
    bullCandle and bullCandle[1] and bullCandle[2] and risingPrice and risingPrice[1] and risingPrice[2]

y    = ta.valuewhen(falling or rising, falling ? lwstPrice : hstPrice, 0)
x1   = ta.valuewhen(falling or rising, time, 0)

exhaustVol     = nzVolume > i_vSpikeThresh * i_vSMA
x1V            = ta.valuewhen(exhaustVol, time, 0)
highVolatility = range_1 > weightedATR
x1hV           = ta.valuewhen(highVolatility, time, 0)

f_getStyle(_s) =>
    _s == 'Solid' ? line.style_solid : _s == 'Dotted' ? line.style_dotted : line.style_dashed

// ================================================================================================== //
// --- NEW v2: HTF BIAS (4H SMA 50) ------------------------------------------------------------- //
// ================================================================================================== //

htf_close  = request.security(syminfo.tickerid, '240', close)
htf_sma50  = request.security(syminfo.tickerid, '240', ta.sma(close, 50))

htfBullish = htf_close > htf_sma50
htfBearish = htf_close < htf_sma50

// ================================================================================================== //
// --- NEW v2: PDH / PDL -------------------------------------------------------------------- //
// ================================================================================================== //

pdh = request.security(syminfo.tickerid, 'D', high[1])
pdl = request.security(syminfo.tickerid, 'D', low[1])

// Track whether PDH/PDL has been swept since last daily open
// Swept = price exceeded the level on current day. Reset at day start.
var bool pdhSweptToday = false
var bool pdlSweptToday = false

if ta.change(time('D')) != 0
    pdhSweptToday := false
    pdlSweptToday := false

if high > pdh
    pdhSweptToday := true
if low < pdl
    pdlSweptToday := true

// ================================================================================================== //
// --- NEW v2: LOSS STREAK KILL SWITCH ---------------------------------------------------------- //
// ================================================================================================== //

var int lossStreakCount  = 0
var int prevLossTrades   = 0
var int prevWinTrades    = 0

// Detect a new loss (loss count increased since last bar)
newLoss = strategy.losstrades > prevLossTrades
newWin  = strategy.wintrades  > prevWinTrades

if newLoss
    lossStreakCount := lossStreakCount + 1
if newWin
    lossStreakCount := 0

prevLossTrades := strategy.losstrades
prevWinTrades  := strategy.wintrades

canTrade = not i_useLossStreak or lossStreakCount < i_maxLossStreak

// ================================================================================================== //
// --- ADAPTIVE LEARNING ENGINE ------------------------------------------------------------------ //
// ================================================================================================== //

// Signal indices: 0=BOS, 1=CHoCH, 2=OB, 3=FVG, 4=LIQ, 5=KZ_Asian, 6=KZ_London, 7=KZ_NY
var array<float> sig_wins  = array.new_float(8, 0.)
var array<float> sig_total = array.new_float(8, 0.)

var array<int>   pend_bar   = array.new_int(8,   -999)
var array<float> pend_price = array.new_float(8, 0.)
var array<int>   pend_dir   = array.new_int(8,   0)

EVAL_BARS = 5

f_confidence(idx) =>
    t = array.get(sig_total, idx)
    t < 3 ? 0.5 : array.get(sig_wins, idx) / t

f_record(idx, direction) =>
    array.set(pend_bar,   idx, bar_index)
    array.set(pend_price, idx, close)
    array.set(pend_dir,   idx, direction)
    array.set(sig_total,  idx, array.get(sig_total, idx) + 1)

f_evaluate() =>
    for idx = 0 to 7
        pb = array.get(pend_bar, idx)
        if pb >= 0 and bar_index - pb == EVAL_BARS
            entry   = array.get(pend_price, idx)
            dir     = array.get(pend_dir, idx)
            won     = dir == 1 ? close > entry : close < entry
            if won
                array.set(sig_wins, idx, array.get(sig_wins, idx) + 1)
            array.set(pend_bar, idx, -999)

f_evaluate()

f_labelColor(baseColor, confScore) =>
    confScore >= i_highConfThresh / 100.0 ? baseColor :
     confScore >= i_lowConfThresh  / 100.0 ? color.new(baseColor, 55) :
     color.new(color.gray, 75)

f_boxColor(baseColor, confScore) =>
    confScore >= i_highConfThresh / 100.0 ? baseColor :
     confScore >= i_lowConfThresh  / 100.0 ? color.new(baseColor, 85) :
     color.new(color.gray, 92)

f_confStr(confScore, total) =>
    total < 3 ? ' [new]' : ' [' + str.tostring(math.round(confScore * 100)) + '%]'

// ================================================================================================== //
// --- ORIGINAL S&R PLOTTING --------------------------------------------------------------------- //
// ================================================================================================== //

var line srLine = na
if i_isSnR and falling and sProcessing
    if falling == falling[1]
        line.delete(srLine[1])
    srLine := line.new(x1, y, x2, y, xloc.bar_time, extend.none, i_srLnColor, f_getStyle(i_srLnStyle), i_srLnWidth)
    srLine

if i_isSnR and rising and sProcessing
    if rising == rising[1]
        line.delete(srLine[1])
    srLine := line.new(x1, y, x2, y, xloc.bar_time, extend.none, i_srLnColor, f_getStyle(i_srLnStyle), i_srLnWidth)
    srLine

var line spikeLine  = na
var line spikeLine1 = na
var line spikeLine2 = na
var line spikeLine3 = na

if i_isSnRSpike and exhaustVol and sProcessing
    if bullCandle
        if i_spLnBullLevel == 'High'
            if exhaustVol == exhaustVol[1] and not bearCandle[1]
                line.delete(spikeLine[1])
            spikeLine := line.new(x1V, high, x2, high, xloc.bar_time, extend.none, i_spLnColor, f_getStyle(i_spLnStyle), i_spLnWidth)
            spikeLine
        else if i_spLnBullLevel == 'Close'
            if exhaustVol == exhaustVol[1] and not bearCandle[1]
                line.delete(spikeLine[1])
            spikeLine := line.new(x1V, close, x2, close, xloc.bar_time, extend.none, i_spLnColor, f_getStyle(i_spLnStyle), i_spLnWidth)
            spikeLine
        else
            if exhaustVol == exhaustVol[1] and not bearCandle[1]
                line.delete(spikeLine1[1])
                line.delete(spikeLine2[1])
                line.delete(spikeLine3[1])
            spikeLine1 := line.new(x1V, close, x2, close, xloc.bar_time, extend.none, i_spLnColor, f_getStyle(i_spLnStyle), i_spLnWidth)
